<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main App Theme -->
    <style name="Theme.RabbiHossainLTD" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/neon_green</item>
        <item name="colorPrimaryVariant">@color/neon_green_dark</item>
        <item name="colorOnPrimary">@color/amoled_black</item>
        <item name="colorSecondary">@color/neon_cyan</item>
        <item name="colorOnSecondary">@color/amoled_black</item>
        <item name="android:statusBarColor">@color/amoled_black</item>
        <item name="android:navigationBarColor">@color/amoled_black</item>
        <item name="android:windowBackground">@color/amoled_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Splash Screen Theme - full black, no title bar -->
    <style name="Theme.Splash" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:statusBarColor">@color/amoled_black</item>
        <item name="android:navigationBarColor">@color/amoled_black</item>
        <item name="android:windowBackground">@color/amoled_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Dark Alert Dialog -->
    <style name="DarkAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/neon_green</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/NeonPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/NeonNegativeButton</item>
    </style>

    <style name="NeonPositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/neon_green</item>
    </style>

    <style name="NeonNegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
