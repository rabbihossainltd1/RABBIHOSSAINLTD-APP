<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/amoled_black">

    <!-- Outer glow ring 2 (larger, more transparent) -->
    <View
        android:id="@+id/glowCircle2"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/glow_circle_outer"
        app:layout_constraintBottom_toBottomOf="@id/logoContainer"
        app:layout_constraintEnd_toEndOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="@id/logoContainer"
        app:layout_constraintTop_toTopOf="@id/logoContainer"
        android:alpha="0" />

    <!-- Inner glow ring 1 -->
    <View
        android:id="@+id/glowCircle1"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/glow_circle_inner"
        app:layout_constraintBottom_toBottomOf="@id/logoContainer"
        app:layout_constraintEnd_toEndOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="@id/logoContainer"
        app:layout_constraintTop_toTopOf="@id/logoContainer"
        android:alpha="0" />

    <!-- Logo container (shield icon + initials) -->
    <FrameLayout
        android:id="@+id/logoContainer"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:layout_constraintBottom_toTopOf="@+id/appNameText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42"
        android:alpha="0">

        <!-- Shield background -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_shield_logo"
            android:scaleType="fitCenter" />

        <!-- Initials overlay -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="RL"
            android:textColor="@color/amoled_black"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1" />

    </FrameLayout>

    <!-- App Name -->
    <TextView
        android:id="@+id/appNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:letterSpacing="0.05"
        android:layout_marginTop="28dp"
        android:alpha="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoContainer" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/splash_subtitle"
        android:textColor="@color/neon_cyan"
        android:textSize="13sp"
        android:letterSpacing="0.15"
        android:textAllCaps="true"
        android:layout_marginTop="8dp"
        android:alpha="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appNameText" />

    <!-- Loading dots container -->
    <LinearLayout
        android:id="@+id/loadingDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="60dp"
        android:alpha="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleText">

        <View
            android:id="@+id/dot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/loading_dot" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/loading_dot_cyan" />

        <View
            android:id="@+id/dot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/loading_dot" />

    </LinearLayout>

    <!-- Version text at bottom -->
    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="32dp"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
